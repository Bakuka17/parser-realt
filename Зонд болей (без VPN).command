#!/bin/bash
# Зонд болей собственников (customer research) — сбор реальных реплик с бел. форумов.
#
# ⚠ ЗАПУСКАТЬ БЕЗ VPN (Psiphon OFF)! С белорусского IP форумы onliner/realt отдают
#   живой HTML; под VPN — капча/гео-блок, зонд соберёт мусор.
#
# Что делает: ходит по форумам, сохраняет страницы + чистый текст в research_probe_out/,
#   помечает 🔥 самые «болевые» (риелтор/комиссия/не могу продать/висит…).
# Прерывать можно (просто закрой окно). Когда допишет «Готово» — включай VPN и
#   возвращайся к Claude, я разберу папку и вытащу цитаты.
cd "$(dirname "$0")" || exit 1
./bin/python research_probe.py
echo ""
echo "Окно можно закрыть. Не забудь включить VPN перед возвратом к Claude."
