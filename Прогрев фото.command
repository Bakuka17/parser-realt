#!/bin/bash
# Двойной клик: скачивает фото всех объявлений в локальный кэш (web/photos_cache/),
# чтобы в дашборде все карточки сразу были с полноразмерными фото — без докачки на лету.
# Идемпотентно: уже скачанное пропускает, можно прерывать (Ctrl+C) и запускать снова.
# Гонит долго (тысячи фото, ~1.5 ч). Можно под VPN или без — kufar тянется аккуратно.
cd "$(dirname "$0")" || exit 1
echo "Прогрев фото-кэша дашборда. Это может занять ~1.5 часа (тысячи фото)."
echo "Прервать — Ctrl+C, прогресс сохранится, повторный запуск продолжит с места."
echo
./bin/python web/prefetch_photos.py
echo
echo "Готово. Закройте окно."
